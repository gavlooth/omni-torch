(import "lib/torch.omni" :all)
(define u (tensor/randn '(1 4 8)))

(define (spectral-lap u sl)
  (let (uh (_wrap (omni-torch-fft-rfft u.handle 1))
        fr (_wrap (omni-torch-fft-fftfreq sl))
        k2 (tensor/neg (tensor/pow fr 2))
        nf (+ (/ sl 2) 1)
        kb (tensor/reshape k2 (list 1 nf 1))
        sc (_wrap (omni-torch-mul uh.handle kb.handle))
        r  (_wrap (omni-torch-fft-irfft sc.handle sl 1)))
    r))

(define r1 (spectral-lap u 4))
(println "spectral-lap call 1 OK")
(define r2 (spectral-lap u 4))
(println "spectral-lap call 2 OK")
(define r3 (spectral-lap u 4))
(println "spectral-lap call 3 OK")
(define r4 (spectral-lap u 4))
(println "spectral-lap call 4 OK")
(define r5 (spectral-lap u 4))
(println "spectral-lap call 5 OK")
(println "ALL OK")
