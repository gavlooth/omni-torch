;; Diffusion LLM with Linear Attention + Wave-PDE Layers
;;
;; Architecture: N blocks of (Linear Attention -> Wave-PDE), interleaved.
;; Based on:
;;   - Linear Attention: Katharopoulos et al., "Transformers are RNNs" (2020)
;;   - Wave-PDE Layer: Vejendla, "Wave-PDE Nets" (arxiv:2510.04304)
;;
;; Run:  make diffusion-llm

(import "../lib/torch.omni" :all)

;; ================================================================
;;  Hyperparameters
;; ================================================================
(define DIM 16)
(define SEQ 8)
(define N-BLOCKS 2)
(define WAVE-STEPS 2)
(define T-DIFFUSION 10)

;; ================================================================
;;  Spectral Laplacian via FFT
;; ================================================================
(define (spectral-laplacian u seq-len)
  (let (u-hat  (_wrap (omni-torch-fft-rfft u.handle 1))
        n-freq (+ (/ seq-len 2) 1)
        freqs-full (_wrap (omni-torch-fft-fftfreq seq-len))
        freqs  (tensor/slice freqs-full 0 0 n-freq)
        k2-neg (tensor/neg (tensor/pow freqs 2))
        k2-bc  (tensor/reshape k2-neg (list 1 n-freq 1))
        scaled (_wrap (omni-torch-mul u-hat.handle k2-bc.handle))
        result (_wrap (omni-torch-fft-irfft scaled.handle seq-len 1)))
    result))

;; ================================================================
;;  Wave-PDE Layer (Velocity-Verlet symplectic integration)
;; ================================================================
(define (wave-pde-step u v c gamma dt seq-len)
  (let (lap    (spectral-laplacian u seq-len)
        c2-lap (* (* c c) lap)
        accel  (- c2-lap (* gamma v))
        v-half (+ v (* accel (* dt 0.5)))
        u-next (+ u (* v-half dt))
        lap2   (spectral-laplacian u-next seq-len)
        c2-l2  (* (* c c) lap2)
        acc2   (- c2-l2 (* gamma v-half))
        v-next (+ v-half (* acc2 (* dt 0.5))))
    (list u-next v-next)))

(define (wave-pde-forward u c-raw gamma-raw n-steps seq-len)
  (let (c     (_wrap (omni-torch-softplus c-raw.handle))
        gamma (_wrap (omni-torch-softplus gamma-raw.handle))
        dt    0.1
        v     (tensor/zeros u.shape))
    (let loop (step 0 u-cur u v-cur v)
      (if (= step n-steps) u-cur
        (let (result (wave-pde-step u-cur v-cur c gamma dt seq-len)
              u-n (car result)
              v-n (car (cdr result)))
          (loop (+ step 1) u-n v-n))))))

;; ================================================================
;;  Linear Attention
;; ================================================================
(define (elu-plus-one x)
  (let (ex   (tensor/exp x)
        pos  (+ x 1)
        z    (tensor/zeros x.shape)
        mask (_wrap (omni-torch-gt x.handle z.handle)))
    (_wrap (omni-torch-where mask.handle pos.handle ex.handle))))

(define (linear-attention x wq wk wv wo)
  (let (q     (elu-plus-one (tensor/matmul x wq))
        k     (elu-plus-one (tensor/matmul x wk))
        v     (tensor/matmul x wv)
        k-t   (tensor/transpose k 1 2)
        kv    (tensor/matmul k-t v)
        qkv   (tensor/matmul q kv)
        k-sum (tensor/unsqueeze (tensor/sum-dim k 1) 1)
        z     (tensor/unsqueeze (tensor/sum-dim (* q k-sum) 2) 2)
        z-safe (tensor/clamp z 0.0001 1000000.0)
        out   (/ qkv z-safe))
    (tensor/matmul out wo)))

;; ================================================================
;;  RMS Norm
;; ================================================================
(define (rms-norm x)
  (_wrap (omni-torch-rms-norm x.handle 2)))

;; ================================================================
;;  Demo
;; ================================================================
(println "=== Diffusion LLM: Linear Attention + Wave-PDE ===")
(println (format "Config: dim=%d seq=%d blocks=%d wave-steps=%d" DIM SEQ N-BLOCKS WAVE-STEPS))

;; Create weights for one block
(println "\nInitializing block 0...")
(define wq0 (* (tensor/randn (list DIM DIM)) 0.02))
(define wk0 (* (tensor/randn (list DIM DIM)) 0.02))
(define wv0 (* (tensor/randn (list DIM DIM)) 0.02))
(define wo0 (* (tensor/randn (list DIM DIM)) 0.02))
(define c0  (tensor/randn (list 1 1 DIM)))
(define g0  (tensor/randn (list 1 1 DIM)))
(println "Block 0 weights OK")

;; Create input
(define x (tensor/randn (list 1 SEQ DIM)))
(println (format "Input: (1, %d, %d)" SEQ DIM))

;; Forward: Linear Attention + residual
(println "\nLinear Attention forward...")
(define h (rms-norm x))
(define attn-out (linear-attention h wq0 wk0 wv0 wo0))
(define h1 (+ x attn-out))
(println "Linear Attention OK")

;; Forward: Wave-PDE + residual
(println "Wave-PDE forward...")
(define h2 (rms-norm h1))
(define wave-out (wave-pde-forward h2 c0 g0 WAVE-STEPS SEQ))
(define h3 (+ h1 wave-out))
(println "Wave-PDE OK")

;; Compute "loss" (MSE vs random noise target)
(define target (tensor/randn h3.shape))
(define diff (- h3 target))
(define loss (tensor/item (tensor/mean (* diff diff))))
(println (format "\nForward pass complete. Loss (random init): %.4f" loss))

(println "\nArchitecture verified:")
(println "  Linear Attention (O(n*d^2)) + Wave-PDE (O(n*log(n)))")
(println "  Symplectic Velocity-Verlet + Spectral FFT Laplacian")
(println "  Ready for diffusion training loop.")
