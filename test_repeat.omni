(import "lib/torch.omni" :all)
(define u (tensor/randn '(1 4 8)))

(define (mk-tensor)
  (let (a (tensor/randn '(1 4 8))
        b (tensor/randn '(8 8))
        c (tensor/matmul a b)
        d (tensor/exp c)
        e (+ d c))
    e))

(define r1 (mk-tensor))
(println "call 1 OK")
(define r2 (mk-tensor))
(println "call 2 OK")
