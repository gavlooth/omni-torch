(import "lib/torch.omni" 'all)
(define h (omni-torch-randn-2d 3 4))
(println (format "h=%d" h))
(define nd (omni-torch-dim h))
(println (format "nd=%d" nd))
(define nu (omni-torch-numel h))
(println (format "nu=%d" nu))
(define dt (omni-torch-dtype h))
(println (format "dt=%d" dt))
(define sh (_query-shape h nd))
(println "shape OK")
(println (format "shape len=%d" (length sh)))
(define t (Tensor h sh nd nu dt))
(println "Tensor constructor OK")
(println (format "t.ndim=%d" t.ndim))
