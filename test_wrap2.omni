(import "lib/torch.omni" 'all)
(define t (_wrap (omni-torch-randn-2d 3 4)))
(println (format "t.ndim=%d t.numel=%d" t.ndim t.numel))
(define t2 (* t 2))
(println (format "t2.ndim=%d" t2.ndim))
(define t3 (* (tensor/randn '(16 16)) 0.02))
(println (format "t3.ndim=%d t3.numel=%d" t3.ndim t3.numel))
(println "ALL OK")
