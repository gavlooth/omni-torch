(import "lib/torch.omni" 'all)
(println "1: rms-norm")
(define x (tensor/randn '(1 4 8)))
(define n (tensor/rms-norm x))
(println "   OK")

(println "2: elu-plus-one equivalent")
(define ex (tensor/exp x))
(define pos (+ x 1))
(define zeros-x (tensor/zeros x.shape))
(define mask (_wrap (omni-torch-gt x.handle zeros-x.handle)))
(define epo (_wrap (omni-torch-where mask.handle pos.handle ex.handle)))
(println "   OK")

(println "3: matmul chain")
(define w1 (tensor/randn '(8 8)))
(define q (tensor/matmul x w1))
(define k (tensor/matmul x w1))
(define v (tensor/matmul x w1))
(println "   OK")

(println "4: transpose + matmul")
(define kt (tensor/transpose k 1 2))
(define kv (tensor/matmul kt v))
(println "   OK")

(println "5: full attention chain")
(define qkv (tensor/matmul q kv))
(println "   OK")

(println "6: sum-dim + unsqueeze")
(define ks (tensor/sum-dim k 1))
(define ksu (tensor/unsqueeze ks 1))
(println "   OK")

(println "7: normalizer")
(define prod (* q ksu))
(define z (tensor/sum-dim prod 2))
(define zu (tensor/unsqueeze z 2))
(define zs (tensor/clamp zu 0.0001 1000000.0))
(println "   OK")

(println "8: divide")
(define out (/ qkv zs))
(println "   OK")

(println "9: output projection")
(define proj (tensor/matmul out w1))
(println "   OK - Linear attention works!")
