(import "lib/torch.omni" :all)
(define x (tensor/randn '(1 4 8)))
(define z (tensor/zeros x.shape))
(define mask (_wrap (omni-torch-gt x.handle z.handle)))
(define pos (+ x 1))
(define ex (tensor/exp x))
(define result (_wrap (omni-torch-where mask.handle pos.handle ex.handle)))
(println "elu OK")
(define w1 (* (tensor/randn '(8 8)) 0.02))
(println "w1 OK")
(define q (tensor/matmul result w1))
(println "matmul OK")
(define k (tensor/matmul result w1))
(define v (tensor/matmul result w1))
(println "qkv OK")
(define kt (tensor/transpose k 1 2))
(define kv (tensor/matmul kt v))
(define qkv (tensor/matmul q kv))
(println "attention OK")
(define ks (tensor/sum-dim k 1))
(define ksu (tensor/unsqueeze ks 1))
(define prod (* q ksu))
(define zz (tensor/sum-dim prod 2))
(define zu (tensor/unsqueeze zz 2))
(define zs (tensor/clamp zu 0.0001 1000000.0))
(define out (/ qkv zs))
(define proj (tensor/matmul out w1))
(println "FULL LINEAR ATTENTION OK")
