(import "lib/torch.omni" :all)
(define DIM 8)
(define SEQ 4)

(define (elu1 x)
  (let (ex (tensor/exp x)
        pos (+ x 1)
        z (tensor/zeros x.shape)
        mask (_wrap (omni-torch-gt x.handle z.handle)))
    (_wrap (omni-torch-where mask.handle pos.handle ex.handle))))

(define (linear-attn x wq wk wv wo)
  (let (q (elu1 (tensor/matmul x wq))
        k (elu1 (tensor/matmul x wk))
        v (tensor/matmul x wv)
        kt (tensor/transpose k 1 2)
        kv (tensor/matmul kt v)
        qkv (tensor/matmul q kv)
        ks (tensor/unsqueeze (tensor/sum-dim k 1) 1)
        z (tensor/unsqueeze (tensor/sum-dim (* q ks) 2) 2)
        zs (tensor/clamp z 0.0001 1000000.0)
        out (/ qkv zs))
    (tensor/matmul out wo)))

(define (rms-norm x)
  (_wrap (omni-torch-rms-norm x.handle 2)))

(define (spectral-lap u sl)
  (let (uh (_wrap (omni-torch-fft-rfft u.handle 1))
        fr (_wrap (omni-torch-fft-fftfreq sl))
        k2 (tensor/neg (tensor/pow fr 2))
        nf (+ (/ sl 2) 1)
        kb (tensor/reshape k2 (list 1 nf 1))
        sc (_wrap (omni-torch-mul uh.handle kb.handle))
        r  (_wrap (omni-torch-fft-irfft sc.handle sl 1)))
    r))

(define (wave-step u v c g dt sl)
  (let (lap (spectral-lap u sl)
        acc (- (* (* c c) lap) (* g v))
        vh (+ v (* acc (* dt 0.5)))
        un (+ u (* vh dt))
        l2 (spectral-lap un sl)
        a2 (- (* (* c c) l2) (* g vh))
        vn (+ vh (* a2 (* dt 0.5))))
    (list un vn)))

(define (wave-fwd u cr gr steps sl)
  (let (c (_wrap (omni-torch-softplus cr.handle))
        g (_wrap (omni-torch-softplus gr.handle))
        v (tensor/zeros u.shape))
    (let loop (s 0 uc u vc v)
      (if (= s steps) uc
        (let (r (wave-step uc vc c g 0.1 sl))
          (loop (+ s 1) (car r) (car (cdr r))))))))

;; Init weights
(println "Init...")
(define wq (* (tensor/randn (list DIM DIM)) 0.02))
(define wk (* (tensor/randn (list DIM DIM)) 0.02))
(define wv (* (tensor/randn (list DIM DIM)) 0.02))
(define wo (* (tensor/randn (list DIM DIM)) 0.02))
(define cr (tensor/randn (list 1 1 DIM)))
(define gr (tensor/randn (list 1 1 DIM)))
(println "Weights OK")

(define x (tensor/randn (list 1 SEQ DIM)))
(println "Input OK")

;; Block: LA + residual
(println "LA...")
(define h (rms-norm x))
(define a (linear-attn h wq wk wv wo))
(define h1 (+ x a))
(println "LA OK")

;; Block: Wave-PDE + residual
(println "Wave...")
(define h2 (rms-norm h1))
(define w (wave-fwd h2 cr gr 2 SEQ))
(define h3 (+ h1 w))
(println "Wave OK")

;; Loss
(define tgt (tensor/randn h3.shape))
(define d (- h3 tgt))
(define loss (tensor/item (tensor/mean (* d d))))
(println (format "Loss: %.4f" loss))
(println "FULL BLOCK OK")
